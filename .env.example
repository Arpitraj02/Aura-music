# ── Aura Music – Environment Variables ──────────────────────────────────────

# Gemini AI API key (optional – used for AI-generated playlists/recommendations)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# The public URL where your app is hosted (used for CORS and self-referential links)
APP_URL="http://localhost:3001"

# Port for the Express API/server (default: 3001)
PORT=3001

# Optional: absolute path to the yt-dlp binary if not on $PATH
# YTDLP_PATH="/usr/local/bin/yt-dlp"

# Optional: override API port used by Vite proxy in development (default: 3001)
# API_PORT=3001
